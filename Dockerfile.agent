FROM python:3.12-slim

WORKDIR /app

# System deps needed by Chromium headless on Linux
RUN apt-get update && apt-get install -y \
    fonts-liberation \
    fonts-noto \
    && rm -rf /var/lib/apt/lists/*

COPY agent/requirements.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Install Chromium + all its system-level dependencies
RUN playwright install chromium --with-deps

COPY api/ api/
COPY agent/ agent/
COPY wdd/ wdd/

ENV AGENT_PORT=8021
ENV HEADLESS=1
ENV STORAGE_PATH=/app/storage

EXPOSE ${AGENT_PORT}

CMD ["sh", "-c", "python -m agent --host 0.0.0.0 --port ${AGENT_PORT}"]
